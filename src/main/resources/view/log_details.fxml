<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.logmonitoring.controller.LogDetailsController">

    <top>
        <HBox style="-fx-padding: 10; -fx-background-color: #f5f5f5;" alignment="CENTER_LEFT">
            <Label text="Flagged Logs Report" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="15" style="-fx-padding: 15;">
            <VBox spacing="5" VBox.vgrow="ALWAYS">
                <Label text="Flagged Logs" style="-fx-font-weight: bold;"/>
                <TableView fx:id="tableFlaggedLogs" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn text="Timestamp" fx:id="colTimestamp" prefWidth="150"/>
                        <TableColumn text="Level" fx:id="colLevel" prefWidth="80"/>
                        <TableColumn text="Source" fx:id="colSource" prefWidth="120"/>
                        <TableColumn text="Message" fx:id="colMessage" prefWidth="250"/>
                        <TableColumn text="User" fx:id="colUser" prefWidth="100"/>
                        <TableColumn text="Source IP" fx:id="colSrcIp" prefWidth="120"/>
                        <TableColumn text="Note" fx:id="colNote" prefWidth="150"/>
                        <TableColumn text="Status" fx:id="colStatus" prefWidth="100"/>
                    </columns>
                </TableView>
            </VBox>

            <VBox spacing="10" style="-fx-padding: 10; -fx-background-color: #f9f9f9;">
                <Label text="Options" style="-fx-font-weight: bold;"/>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Note:"/>
                    <TextArea fx:id="txtNote" promptText="Enter note for selected log..." prefRowCount="2" prefWidth="400"/>
                    <Button text="Add Note" onAction="#onAddNote" prefWidth="100"/>
                </HBox>
            </VBox>
        </VBox>
    </center>

    <bottom>
        <HBox spacing="10" alignment="CENTER_RIGHT"
              style="-fx-padding: 12; -fx-background-color: #f0f0f0; -fx-border-color: #d0d0d0; -fx-border-width: 1 0 0 0;">
            <Button text="Review Saved Notes" onAction="#onReviewSavedNotes" prefWidth="150" minWidth="150" maxWidth="150" style="-fx-background-color: #5a7fa3; -fx-text-fill: white; -fx-background-radius: 3;"/>
            <Label text="Export Format:"/>
            <ComboBox fx:id="comboExportFormat" prefWidth="120" minWidth="120" maxWidth="120" onAction="#onExportReport"/>
            <Button text="Back" onAction="#onBack" prefWidth="130" minWidth="130" maxWidth="130" style="-fx-background-color: #e0e0e0; -fx-background-radius: 3;"/>
            <Button text="Logout" onAction="#onLogout" prefWidth="130" minWidth="130" maxWidth="130" style="-fx-background-color: #e0e0e0; -fx-background-radius: 3;"/>
        </HBox>
    </bottom>

</BorderPane>
