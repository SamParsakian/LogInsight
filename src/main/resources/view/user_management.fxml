<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.logmonitoring.controller.UserManagementController"
            prefWidth="700"
            prefHeight="500">

    <top>
        <HBox style="-fx-padding: 15; -fx-background-color: #f5f5f5;" alignment="CENTER_LEFT">
            <Label text="User Management" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="15" style="-fx-padding: 15;">
            <VBox spacing="5" VBox.vgrow="ALWAYS">
                <Label text="Users" style="-fx-font-weight: bold;"/>
                <TableView fx:id="tableUsers" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn text="Username" fx:id="colUsername" prefWidth="200"/>
                        <TableColumn text="Password" fx:id="colPassword" prefWidth="200"/>
                        <TableColumn text="Created At" fx:id="colCreatedAt" prefWidth="250"/>
                    </columns>
                </TableView>
            </VBox>

            <VBox spacing="10" style="-fx-padding: 10; -fx-background-color: #f9f9f9;">
                <Label text="User Details" style="-fx-font-weight: bold;"/>
                <GridPane hgap="10" vgap="10" alignment="CENTER_LEFT">
                    <columnConstraints>
                        <ColumnConstraints minWidth="100" prefWidth="100" halignment="RIGHT"/>
                        <ColumnConstraints minWidth="250" prefWidth="250" hgrow="ALWAYS"/>
                    </columnConstraints>
                    <Label text="Username:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="txtUsername" promptText="Enter username" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="250"/>
                    <Label text="Password:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <PasswordField fx:id="txtPassword" promptText="Enter password" GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="250"/>
                </GridPane>
            </VBox>
        </VBox>
    </center>

    <bottom>
        <HBox spacing="10" alignment="CENTER_RIGHT"
              style="-fx-padding: 12; -fx-background-color: #f0f0f0; -fx-border-color: #d0d0d0; -fx-border-width: 1 0 0 0;">
            <Button text="Add" fx:id="btnAdd" onAction="#onAdd" prefWidth="100" minWidth="100" maxWidth="100" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-background-radius: 3;"/>
            <Button text="Update" fx:id="btnUpdate" onAction="#onUpdate" prefWidth="100" minWidth="100" maxWidth="100" style="-fx-background-color: #5a7fa3; -fx-text-fill: white; -fx-background-radius: 3;"/>
            <Button text="Delete" fx:id="btnDelete" onAction="#onDelete" prefWidth="100" minWidth="100" maxWidth="100" style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-background-radius: 3;"/>
            <Button text="Clear" fx:id="btnClear" onAction="#onClear" prefWidth="100" minWidth="100" maxWidth="100" style="-fx-background-color: #e0e0e0; -fx-background-radius: 3;"/>
            <Button text="Close" onAction="#onClose" prefWidth="100" minWidth="100" maxWidth="100" style="-fx-background-color: #e0e0e0; -fx-background-radius: 3;"/>
        </HBox>
    </bottom>

</BorderPane>
