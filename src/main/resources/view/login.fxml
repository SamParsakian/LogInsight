<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.logmonitoring.controller.LoginController"
      spacing="15"
      alignment="CENTER"
      prefWidth="400"
      prefHeight="280"
      style="-fx-padding: 20;">

    <Label text="Log Monitoring Tool"
           style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <Label text="Login"
           style="-fx-font-size: 16px;"/>

    <VBox spacing="10" alignment="CENTER" prefWidth="300">
        <TextField fx:id="txtUsername"
                   promptText="Username"
                   prefWidth="300"
                   prefHeight="35"/>

        <PasswordField fx:id="txtPassword"
                       promptText="Password"
                       prefWidth="300"
                       prefHeight="35"/>
    </VBox>

    <HBox spacing="10" alignment="CENTER">
        <Button text="Login"
                onAction="#onLogin"
                prefWidth="100"
                prefHeight="35"
                defaultButton="true"/>

        <Button text="Exit"
                onAction="#onExit"
                prefWidth="100"
                prefHeight="35"
                cancelButton="true"/>
    </HBox>

    <Label fx:id="lblError"
           style="-fx-text-fill: red; -fx-font-size: 12px;"
           text=""
           visible="false"/>

</VBox>
