<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.logmonitoring.controller.MainController">

    <top>
        <VBox>
            <MenuBar>
                <Menu text="File">
                    <MenuItem text="Open Log File" onAction="#onOpenLogFile"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="User Management" onAction="#onUserManagement"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Logout" onAction="#onLogout"/>
                    <SeparatorMenuItem/>
                    <MenuItem text="Exit" onAction="#onExit"/>
                </Menu>
                <Menu text="Help">
                    <MenuItem text="About" onAction="#onAbout"/>
                </Menu>
            </MenuBar>

            <VBox style="-fx-padding: 12; -fx-background-color: #f0f0f0; -fx-border-color: #d0d0d0; -fx-border-width: 0 0 1 0;" spacing="12">
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Button text="Upload Log File" onAction="#onOpenLogFile" prefWidth="150" minWidth="150" maxWidth="150" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-background-radius: 3; -fx-font-weight: bold;"/>
                </HBox>

                <Label text="Filters" style="-fx-font-weight: bold; -fx-font-size: 14px; -fx-text-fill: #333333;"/>

                <GridPane hgap="12" vgap="10" alignment="CENTER_LEFT">
                    <columnConstraints>
                        <ColumnConstraints minWidth="90" prefWidth="100" halignment="RIGHT"/>
                        <ColumnConstraints minWidth="180" prefWidth="180" hgrow="NEVER"/>
                        <ColumnConstraints minWidth="90" prefWidth="100" halignment="RIGHT"/>
                        <ColumnConstraints minWidth="180" prefWidth="180" hgrow="NEVER"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>

                    <Label text="Date From:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <DatePicker fx:id="dateFrom" GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="180" minWidth="180" maxWidth="180"/>
                    <Label text="Date To:" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
                    <DatePicker fx:id="dateTo" GridPane.columnIndex="3" GridPane.rowIndex="0" prefWidth="180" minWidth="180" maxWidth="180"/>

                    <Label text="Time From:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <TextField fx:id="timeFrom" promptText="HH:mm" GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="180" minWidth="180" maxWidth="180"/>
                    <Label text="Time To:" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
                    <TextField fx:id="timeTo" promptText="HH:mm" GridPane.columnIndex="3" GridPane.rowIndex="1" prefWidth="180" minWidth="180" maxWidth="180"/>

                    <Label text="Log Level:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <ComboBox fx:id="comboLevel" GridPane.columnIndex="1" GridPane.rowIndex="2" prefWidth="180" minWidth="180" maxWidth="180"/>
                    <Label text="Source:" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
                    <TextField fx:id="txtSource" promptText="Source" GridPane.columnIndex="3" GridPane.rowIndex="2" prefWidth="180" minWidth="180" maxWidth="180"/>

                    <Label text="User:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <TextField fx:id="txtUser" promptText="User" GridPane.columnIndex="1" GridPane.rowIndex="3" prefWidth="180" minWidth="180" maxWidth="180"/>
                    <Label text="IP:" GridPane.columnIndex="2" GridPane.rowIndex="3"/>
                    <TextField fx:id="txtIp" promptText="IP Address" GridPane.columnIndex="3" GridPane.rowIndex="3" prefWidth="180" minWidth="180" maxWidth="180"/>
                </GridPane>

                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Button text="Apply Filter" onAction="#onApplyFilter" prefWidth="130" minWidth="130" maxWidth="130" style="-fx-background-color: #5a7fa3; -fx-text-fill: white; -fx-background-radius: 3;"/>
                    <Button text="Clear Filter" onAction="#onClearFilter" prefWidth="130" minWidth="130" maxWidth="130" style="-fx-background-color: #e0e0e0; -fx-background-radius: 3;"/>
                </HBox>
            </VBox>
        </VBox>
    </top>

    <center>
        <TableView fx:id="tableLogs">
            <columns>
                <TableColumn text="Timestamp" fx:id="colTimestamp" prefWidth="150"/>
                <TableColumn text="Level" fx:id="colLevel" prefWidth="80"/>
                <TableColumn text="Source" fx:id="colSource" prefWidth="120"/>
                <TableColumn text="Message" fx:id="colMessage" prefWidth="300"/>
                <TableColumn text="User" fx:id="colUser" prefWidth="100"/>
                <TableColumn text="Source IP" fx:id="colSrcIp" prefWidth="120"/>
            </columns>
        </TableView>
    </center>

    <bottom>
        <HBox spacing="10" alignment="CENTER_RIGHT"
              style="-fx-padding: 12; -fx-background-color: #f0f0f0; -fx-border-color: #d0d0d0; -fx-border-width: 1 0 0 0;">
            <Button text="User Management" onAction="#onUserManagement" prefWidth="150" minWidth="150" maxWidth="150" style="-fx-background-color: #5a7fa3; -fx-text-fill: white; -fx-background-radius: 3;"/>
            <Button text="Graph View" onAction="#onGraphView" prefWidth="130" minWidth="130" maxWidth="130" style="-fx-background-color: #e0e0e0; -fx-background-radius: 3;"/>
            <Button text="Reports" onAction="#onReports" prefWidth="130" minWidth="130" maxWidth="130" style="-fx-background-color: #e0e0e0; -fx-background-radius: 3;"/>
        </HBox>
    </bottom>

</BorderPane>
